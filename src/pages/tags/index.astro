---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header.tsx';
import Footer from '../../components/react/Footer.tsx';
import { createPageTitle } from '../../config/site.ts';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;

// 記号を削除してタグ名をクリーンアップ
function sanitizeTag(tag: string): string {
  // 記号を削除（英数字と日本語以外）
  return tag.replace(/[^\w\u3040-\u309F\u30A0-\u30FF\u4E00-\u9FAF]/g, '');
}

// 全記事を取得
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// タグの統計を計算
const tagStats = allPosts.reduce(
  (acc, post) => {
    post.data.tags.forEach(tag => {
      if (!acc[tag]) {
        acc[tag] = {
          count: 0,
          posts: [],
        };
      }
      acc[tag].count++;
      acc[tag].posts.push(post);
    });
    return acc;
  },
  {} as Record<string, { count: number; posts: any[] }>
);

// タグを記事数順にソート
const sortedTags = Object.entries(tagStats)
  .sort(([, a], [, b]) => b.count - a.count)
  .map(([tag, stats]) => ({ tag, count: stats.count }));
---

<BaseLayout title={createPageTitle('タグ一覧')}>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Header Section -->
      <section class="bg-gray-50 dark:bg-gray-800/50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <h1
              class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
              タグ一覧
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              (全 {sortedTags.length} タグ）
            </p>
          </div>
        </div>
      </section>

      <!-- Tags Grid -->
      <section class="py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          {
            sortedTags.length > 0 ? (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {sortedTags.map(({ tag, count }) => (
                  <a
                    href={`/tags/${sanitizeTag(tag)}/`}
                    class="group block p-6 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
                  >
                    <div class="text-center">
                      <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-200 dark:group-hover:bg-blue-900/50 transition-colors">
                        <svg
                          class="w-6 h-6 text-blue-600 dark:text-blue-400"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100 2 1 1 0 000-2z"
                            clip-rule="evenodd"
                          />
                        </svg>
                      </div>
                      <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-2">
                        #{tag}
                      </h2>
                      <p class="text-sm text-gray-500 dark:text-gray-400">
                        {count} 記事
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <svg
                  class="mx-auto h-12 w-12 text-gray-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                  />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">
                  タグがありません
                </h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                  まだタグが作成されていません。
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
