---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header.tsx';
import Footer from '../../components/react/Footer.tsx';
import CategoryGrid from '../../components/react/CategoryGrid.tsx';
import { getBlogPosts } from '../../utils/content.ts';

const currentPath = Astro.url.pathname;

// 全記事を取得（環境に応じてドラフトを表示）
const allPosts = await getBlogPosts();

// カテゴリの統計を計算
const categoryStats = allPosts.reduce(
  (acc, post) => {
    const category = post.data.category;
    if (category) {
      if (!acc[category]) {
        acc[category] = {
          count: 0,
          posts: [],
        };
      }
      acc[category].count++;
      acc[category].posts.push(post);
    }
    return acc;
  },
  {} as Record<string, { count: number; posts: any[] }>
);

// カテゴリを記事数順にソート
const sortedCategories = Object.entries(categoryStats)
  .sort(([, a], [, b]) => b.count - a.count)
  .map(([category, stats]) => ({ category, count: stats.count }));
---

<BaseLayout
  title="カテゴリ一覧 - Tech Blog"
  description="ブログで使用されているカテゴリの一覧ページです。興味のあるカテゴリから記事を探すことができます。"
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Header Section -->
      <section class="bg-gray-50 dark:bg-gray-800/50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <h1
              class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
              カテゴリ一覧
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              （全 {sortedCategories.length} カテゴリ）
            </p>
          </div>
        </div>
      </section>

      <!-- Categories Grid with Search -->
      <section class="py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <CategoryGrid client:load initialCategories={sortedCategories} />
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
