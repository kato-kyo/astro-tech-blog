---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header.tsx';
import Footer from '../../components/react/Footer.tsx';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;

// 記号を削除してカテゴリ名をクリーンアップ
function sanitizeCategory(category: string): string {
  // 記号を削除（英数字と日本語以外）
  return category.replace(/[^\w\u3040-\u309F\u30A0-\u30FF\u4E00-\u9FAF]/g, '');
}

// 全記事を取得
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// カテゴリの統計を計算
const categoryStats = allPosts.reduce(
  (acc, post) => {
    const category = post.data.category;
    if (category) {
      if (!acc[category]) {
        acc[category] = {
          count: 0,
          posts: [],
        };
      }
      acc[category].count++;
      acc[category].posts.push(post);
    }
    return acc;
  },
  {} as Record<string, { count: number; posts: any[] }>
);

// カテゴリを記事数順にソート
const sortedCategories = Object.entries(categoryStats)
  .sort(([, a], [, b]) => b.count - a.count)
  .map(([category, stats]) => ({ category, count: stats.count }));
---

<BaseLayout
  title="カテゴリ一覧 - Tech Blog"
  description="ブログで使用されているカテゴリの一覧ページです。興味のあるカテゴリから記事を探すことができます。"
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Header Section -->
      <section class="bg-gray-50 dark:bg-gray-800/50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <h1
              class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
              カテゴリ一覧
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              技術分野別にまとめられた記事を探す（全 {sortedCategories.length} カテゴリ）
            </p>
          </div>
        </div>
      </section>

      <!-- Categories Grid -->
      <section class="py-12">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          {
            sortedCategories.length > 0 ? (
              <div class="grid gap-4">
                {sortedCategories.map(({ category, count }) => (
                  <a
                    href={`/categories/${sanitizeCategory(category)}/`}
                    class="group block p-6 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-lg transition-all duration-300"
                  >
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center group-hover:bg-blue-200 dark:group-hover:bg-blue-900/50 transition-colors">
                          <svg
                            class="w-5 h-5 text-blue-600 dark:text-blue-400"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                          </svg>
                        </div>
                        <div>
                          <h2 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                            {category}
                          </h2>
                          <p class="text-sm text-gray-500 dark:text-gray-400">
                            {count} 記事
                          </p>
                        </div>
                      </div>

                      <svg
                        class="w-5 h-5 text-gray-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <svg
                  class="mx-auto h-12 w-12 text-gray-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-5l-2-2H5a2 2 0 00-2 2z"
                  />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">
                  カテゴリがありません
                </h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                  まだカテゴリが作成されていません。
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
