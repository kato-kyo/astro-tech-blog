---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/react/Header.tsx';
import Footer from '../../components/react/Footer.tsx';
import BlogCard from '../../components/react/BlogCard.tsx';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;

export async function getStaticPaths() {
  // 記号を削除してカテゴリ名をクリーンアップ
  function sanitizeCategory(category: string): string {
    // 記号を削除（英数字と日本語以外）
    return category.replace(/[^\w\u3040-\u309F\u30A0-\u30FF\u4E00-\u9FAF]/g, '');
  }

  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const uniqueCategories = [...new Set(allPosts
    .map(post => post.data.category)
    .filter(category => category !== undefined)
  )];

  return uniqueCategories.map(category => {
    const filteredPosts = allPosts
      .filter(post => post.data.category === category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category: sanitizeCategory(category) },
      props: { posts: filteredPosts, category },
    };
  });
}

const { posts, category } = Astro.props;
// カテゴリ名はpropsから取得（オリジナルの表示名）
// URLパラメータは自動的にエンコードされている
---

<BaseLayout
  title={`カテゴリ「${category}」の記事一覧 - Tech Blog`}
  description={`「${category}」カテゴリの記事一覧ページです。${posts.length}件の記事があります。`}
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Header Section -->
      <section class="bg-gray-50 dark:bg-gray-800/50 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <!-- Breadcrumb -->
            <nav class="flex justify-center mb-4" aria-label="Breadcrumb">
              <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                  <a
                    href="/"
                    class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400"
                  >
                    ホーム
                  </a>
                </li>
                <li>
                  <div class="flex items-center">
                    <svg
                      class="w-4 h-4 text-gray-400"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                        clip-rule="evenodd"></path>
                    </svg>
                    <a
                      href="/categories/"
                      class="ml-1 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 md:ml-2"
                    >
                      カテゴリ
                    </a>
                  </div>
                </li>
                <li aria-current="page">
                  <div class="flex items-center">
                    <svg
                      class="w-4 h-4 text-gray-400"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                        clip-rule="evenodd"></path>
                    </svg>
                    <span class="ml-1 text-gray-700 dark:text-gray-300 md:ml-2"
                      >{category}</span
                    >
                  </div>
                </li>
              </ol>
            </nav>

            <div class="flex justify-center mb-4">
              <div
                class="inline-flex items-center px-4 py-2 bg-blue-100 dark:bg-blue-900/30 rounded-full"
              >
                <svg
                  class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-2"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z"
                  />
                </svg>
                <span class="text-blue-600 dark:text-blue-400 font-medium"
                  >{category}</span
                >
              </div>
            </div>

            <h1
              class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
              「{category}」の記事一覧
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              {posts.length} 件の記事があります
            </p>
          </div>
        </div>
      </section>

      <!-- Blog Posts -->
      <section class="py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          {
            posts.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {posts.map(post => (
                  <BlogCard post={post} client:visible />
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <svg
                  class="mx-auto h-12 w-12 text-gray-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">
                  記事がありません
                </h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                  このカテゴリの記事はまだありません。
                </p>
              </div>
            )
          }

          <!-- Back to categories -->
          <div class="mt-12 text-center">
            <a
              href="/categories/"
              class="inline-flex items-center text-blue-600 dark:text-blue-400 font-medium hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
            >
              <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                  clip-rule="evenodd"></path>
              </svg>
              すべてのカテゴリを見る
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout> 