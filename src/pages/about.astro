---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

let aboutEntry = null;
let Content = null;
let hasError = false;
let errorMessage = '';

try {
  // about.mdファイルを取得
  const aboutEntries = await getCollection(
    'pages',
    ({ id }) => id === 'about.md'
  );

  if (aboutEntries && aboutEntries.length > 0) {
    aboutEntry = aboutEntries[0];
    const contentResult = await aboutEntry.render();
    Content = contentResult.Content;
  } else {
    hasError = true;
    errorMessage = 'About page data not found.';
  }
} catch (error) {
  hasError = true;
  errorMessage = `Error loading about page: ${error instanceof Error ? error.message : String(error)}`;
}
---

{
  hasError ? (
    <html>
      <head>
        <title>About - Error</title>
      </head>
      <body>
        <h1>エラーが発生しました</h1>
        <p>{errorMessage}</p>
        <p>開発者コンソールで詳細を確認してください。</p>
      </body>
    </html>
  ) : aboutEntry && Content ? (
    <PageLayout pageData={aboutEntry.data}>
      <Content />
    </PageLayout>
  ) : (
    <html>
      <head>
        <title>About - Loading</title>
      </head>
      <body>
        <h1>読み込み中...</h1>
      </body>
    </html>
  )
}
