---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/react/Header.tsx';
import Footer from '../components/react/Footer.tsx';
import { createPageTitle, SITE_CONFIG } from '../config/site.ts';

// ページが無効化されている場合は404を返す
if (!SITE_CONFIG.pages.showAbout) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found',
  });
}

let aboutEntry = null;
let Content = null;
let hasError = false;

try {
  // about.mdファイルを取得
  const aboutEntries = await getCollection(
    'pages',
    ({ id }) => id === 'about.md'
  );

  if (aboutEntries && aboutEntries.length > 0) {
    aboutEntry = aboutEntries[0];
    const contentResult = await aboutEntry.render();
    Content = contentResult.Content;
  } else {
    hasError = true;
  }
} catch {
  hasError = true;
}

const currentPath = Astro.url.pathname;
---

{
  hasError ? (
    <BaseLayout
      title={createPageTitle('About - エラー')}
      description="ページの読み込み中にエラーが発生しました"
    >
      <div class="min-h-screen flex flex-col">
        <Header currentPath={currentPath} client:load />

        <main class="flex-1">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="text-center">
              <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
                About
              </h1>
              <div class="prose prose-lg dark:prose-invert max-w-none">
                <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
                  Aboutコンテンツがありません
                </p>
                <p class="text-gray-500 dark:text-gray-500">
                  まだAboutコンテンツが作成されていません。
                </p>
              </div>
            </div>
          </div>
        </main>

        <Footer />
      </div>
    </BaseLayout>
  ) : aboutEntry && Content ? (
    <PageLayout pageData={aboutEntry.data}>
      <Content />
    </PageLayout>
  ) : (
    <BaseLayout
      title={createPageTitle('About - 読み込み中')}
      description="ページを読み込み中です"
    >
      <div class="min-h-screen flex flex-col">
        <Header currentPath={currentPath} client:load />

        <main class="flex-1">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="text-center">
              <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
                About
              </h1>
              <div class="prose prose-lg dark:prose-invert max-w-none">
                <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
                  Aboutコンテンツがありません
                </p>
                <p class="text-gray-500 dark:text-gray-500">
                  まだAboutコンテンツが作成されていません。
                </p>
              </div>
            </div>
          </div>
        </main>

        <Footer />
      </div>
    </BaseLayout>
  )
}
