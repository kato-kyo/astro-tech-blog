---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/react/Header.tsx';
import Footer from '../components/react/Footer.tsx';

const currentPath = Astro.url.pathname;
---

<BaseLayout
  title="About - Tech Blog"
  description="Tech Blogの管理人のプロフィールページです。経歴、スキル、実績などを紹介しています。"
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Hero Section -->
      <section
        class="bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 py-16"
      >
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <div class="mb-8">
              <img
                src="https://images.pexels.com/photos/220453/pexels-photo-220453.jpeg?auto=compress&cs=tinysrgb&w=400"
                alt="プロフィール画像"
                class="w-32 h-32 rounded-full mx-auto object-cover border-4 border-white dark:border-gray-700 shadow-lg"
              />
            </div>
            <h1
              class="text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-4"
            >
              About Me
            </h1>
            <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
              こんにちは！Tech Blogの管理人です。
            </p>
          </div>
        </div>
      </section>

      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Introduction -->
        <section class="mb-16">
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <p class="text-lg leading-relaxed">
              私は技術に情熱を持つエンジニアです。このブログでは、日々の学習や実務で得た知識、技術的な発見を共有しています。
              プログラミング、Web開発、インフラ構築など、幅広い分野にわたる記事を執筆しています。
            </p>
            <p class="text-lg leading-relaxed">
              技術は日々進歩していますが、基礎をしっかりと理解し、新しい技術にもチャレンジしていくことを大切にしています。
              このブログが、同じ道を歩む方々の参考になれば幸いです。
            </p>
          </div>
        </section>

        <!-- Skills -->
        <section class="mb-16">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
            スキル・技術スタック
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Frontend -->
            <div
              class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
            >
              <h3
                class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center"
              >
                <svg
                  class="w-6 h-6 text-primary-600 mr-2"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 4a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1V8zm8 0a1 1 0 011-1h4a1 1 0 011 1v2a1 1 0 01-1 1h-4a1 1 0 01-1-1V8zm0 4a1 1 0 011-1h4a1 1 0 011 1v2a1 1 0 01-1 1h-4a1 1 0 01-1-1v-2z"
                    clip-rule="evenodd"></path>
                </svg>
                フロントエンド
              </h3>
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300"
                    >React / Next.js</span
                  >
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 4 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300"
                    >TypeScript</span
                  >
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 4 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300"
                    >Tailwind CSS</span
                  >
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 5 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300">Astro</span>
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 4 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
              </div>
            </div>

            <!-- Backend -->
            <div
              class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
            >
              <h3
                class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center"
              >
                <svg
                  class="w-6 h-6 text-primary-600 mr-2"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm3.293 1.293a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 01-1.414-1.414L7.586 10 5.293 7.707a1 1 0 010-1.414zM11 12a1 1 0 100 2h3a1 1 0 100-2h-3z"
                    clip-rule="evenodd"></path>
                </svg>
                バックエンド
              </h3>
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300">Node.js</span>
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 4 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300">Python</span>
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 3 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300"
                    >PostgreSQL</span
                  >
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 3 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-gray-700 dark:text-gray-300">Docker</span>
                  <div class="flex space-x-1">
                    {
                      Array.from({ length: 5 }, (_, i) => (
                        <div
                          key={i}
                          class={`w-2 h-2 rounded-full ${i < 3 ? 'bg-primary-500' : 'bg-gray-300 dark:bg-gray-600'}`}
                        />
                      ))
                    }
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Experience -->
        <section class="mb-16">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
            経歴・実績
          </h2>

          <div class="space-y-8">
            <div
              class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
            >
              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                  <div
                    class="w-12 h-12 bg-primary-100 dark:bg-primary-900/30 rounded-lg flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-primary-600 dark:text-primary-400"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                </div>
                <div class="flex-1">
                  <h3
                    class="text-lg font-semibold text-gray-900 dark:text-white"
                  >
                    Web開発エンジニア
                  </h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                    2020年〜現在
                  </p>
                  <p class="text-gray-700 dark:text-gray-300">
                    モダンなWeb技術を使用したアプリケーション開発に従事。React、TypeScript、Node.jsを中心とした開発経験を積み、
                    フロントエンドからバックエンドまで幅広く担当。
                  </p>
                </div>
              </div>
            </div>

            <div
              class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
            >
              <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                  <div
                    class="w-12 h-12 bg-primary-100 dark:bg-primary-900/30 rounded-lg flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-primary-600 dark:text-primary-400"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      ></path>
                    </svg>
                  </div>
                </div>
                <div class="flex-1">
                  <h3
                    class="text-lg font-semibold text-gray-900 dark:text-white"
                  >
                    個人プロジェクト
                  </h3>
                  <p class="text-gray-600 dark:text-gray-400 text-sm mb-2">
                    継続中
                  </p>
                  <p class="text-gray-700 dark:text-gray-300">
                    技術ブログの運営、オープンソースプロジェクトへの貢献、新しい技術の学習と実践を通じて、
                    継続的なスキルアップを図っています。
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Contact -->
        <section>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">
            お問い合わせ
          </h2>

          <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-8">
            <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
              技術的な質問、コラボレーション、その他のお問い合わせがございましたら、お気軽にご連絡ください。
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="/contact/"
                class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors"
              >
                <svg
                  class="w-5 h-5 mr-2"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
                  ></path>
                  <path
                    d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
                  ></path>
                </svg>
                お問い合わせフォーム
              </a>

              <div class="flex space-x-4">
                <a
                  href="https://github.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center w-12 h-12 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      fill-rule="evenodd"
                      d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z"
                      clip-rule="evenodd"></path>
                  </svg>
                </a>
                <a
                  href="https://twitter.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center w-12 h-12 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"
                    ></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
