---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/react/Header.tsx';
import Footer from '../components/react/Footer.tsx';
import BlogCard from '../components/react/BlogCard.tsx';
import SearchBox from '../components/SearchBox.astro';
import { getCollection } from 'astro:content';

const currentPath = Astro.url.pathname;

// 最新記事を取得（下書きを除く）
const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft;
});

// 公開日順にソート
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

// 人気タグを取得
const allTags = allPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce(
  (acc, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const popularTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 10)
  .map(([tag, count]) => ({ tag, count }));
---

<BaseLayout
  title="Tech Blog - 技術記事と学習記録"
  description="技術に関する記事や学習記録、開発の知見を共有するブログです。プログラミング、Web開発、インフラなどの情報を発信しています。"
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} client:load />

    <main class="flex-1">
      <!-- Hero Section -->
      <section
        class="bg-gradient-to-br from-gray-50 to-gray-100 dark:from-gray-900 dark:to-gray-800 py-16 lg:py-24"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center">
            <h1
              class="text-4xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6"
            >
              <span
                class="bg-gradient-to-r from-primary-600 to-primary-500 bg-clip-text text-transparent"
              >
                Tech Blog
              </span>
            </h1>
            <p
              class="text-xl lg:text-2xl text-gray-600 dark:text-gray-300 mb-8 max-w-3xl mx-auto leading-relaxed"
            >
              技術に関する記事や学習記録、開発の知見を共有するブログです。<br />
              プログラミング、Web開発、インフラなどの情報を発信しています。
            </p>

            <!-- Search Box -->
            <div class="mb-8">
              <SearchBox />
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/blog/"
                class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-medium rounded-lg hover:bg-primary-700 transition-colors shadow-lg hover:shadow-xl"
              >
                記事一覧を見る
                <svg
                  class="ml-2 w-5 h-5"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
              <a
                href="/about/"
                class="inline-flex items-center px-6 py-3 bg-white dark:bg-gray-800 text-gray-900 dark:text-white font-medium rounded-lg border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              >
                プロフィール
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Recent Posts Section -->
      <section class="py-16 lg:py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-12">
            <h2
              class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
              最新記事
            </h2>
            <p class="text-lg text-gray-600 dark:text-gray-300">
              最近公開した記事をご紹介します
            </p>
          </div>

          {
            recentPosts.length > 0 ? (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
                {recentPosts.map(post => (
                  <BlogCard post={post} client:visible />
                ))}
              </div>
            ) : (
              <div class="text-center py-12">
                <p class="text-gray-600 dark:text-gray-400">
                  まだ記事がありません。
                </p>
              </div>
            )
          }

          <div class="text-center">
            <a
              href="/blog/"
              class="inline-flex items-center px-6 py-3 text-primary-600 dark:text-primary-400 font-medium hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
            >
              すべての記事を見る
              <svg class="ml-2 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Popular Tags Section -->
      {
        popularTags.length > 0 && (
          <section class="py-16 bg-gray-50 dark:bg-gray-800/50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
              <div class="text-center mb-12">
                <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 dark:text-white mb-4">
                  人気のタグ
                </h2>
                <p class="text-lg text-gray-600 dark:text-gray-300">
                  よく使用されているタグから記事を探す
                </p>
              </div>

              <div class="flex flex-wrap justify-center gap-3">
                {popularTags.map(({ tag, count }) => (
                  <a
                    href={`/tags/${encodeURIComponent(tag)}/`}
                    class="inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full border border-gray-200 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-600 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                  >
                    #{tag}
                    <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 px-2 py-1 rounded-full">
                      {count}
                    </span>
                  </a>
                ))}
              </div>

              <div class="text-center mt-8">
                <a
                  href="/tags/"
                  class="inline-flex items-center text-primary-600 dark:text-primary-400 font-medium hover:text-primary-700 dark:hover:text-primary-300 transition-colors"
                >
                  すべてのタグを見る
                  <svg
                    class="ml-2 w-4 h-4"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              </div>
            </div>
          </section>
        )
      }
    </main>

    <Footer />
  </div>
</BaseLayout>
