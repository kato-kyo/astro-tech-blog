---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/react/Header.tsx';
import Footer from '../components/react/Footer.tsx';
import { getSiteConfig, createPageTitle } from '../utils/site-config.ts';
import { format, parseISO } from 'date-fns';
import { ja } from 'date-fns/locale';

import { getCollection } from 'astro:content';
import readingTime from 'reading-time';

const currentPath = Astro.url.pathname;
const siteConfig = await getSiteConfig();

// 最新記事を取得（下書きを除く）
const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft;
});

// 公開日順にソート
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

// 人気タグを取得
const allTags = allPosts.flatMap(post => post.data.tags);
const tagCounts = allTags.reduce(
  (acc, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const popularTags = Object.entries(tagCounts)
  .sort(([, a], [, b]) => b - a)
  .slice(0, 12)
  .map(([tag, count]) => ({ tag, count }));
---

<BaseLayout
  title={await createPageTitle()}
  description={siteConfig.seo.homeDescription}
>
  <div class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} siteConfig={siteConfig} client:load />

    <main class="flex-1">
      <!-- Hero Section -->
      <section class="pt-20 pb-16 lg:pt-28 lg:pb-20">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <p
            class="font-mono text-sm text-primary-500 dark:text-primary-400 mb-4"
          >
            こんにちは 👋
          </p>
          <h1
            class="text-display text-gray-900 dark:text-white mb-6 tracking-tight"
          >
            {siteConfig.title}
          </h1>
          <p
            class="text-lg text-gray-500 dark:text-gray-400 mb-10 leading-relaxed max-w-2xl"
          >
            {siteConfig.seo.homeDescription}
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="/blog/"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-500 hover:bg-primary-600 text-white font-medium rounded-lg"
            >
              記事を読む
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
            {
              siteConfig.pages.showAbout && (
                <a
                  href="/about/"
                  class="inline-flex items-center gap-2 px-5 py-2.5 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white font-medium underline underline-offset-4 decoration-gray-300 dark:decoration-gray-600"
                >
                  About me
                </a>
              )
            }
          </div>
        </div>
      </section>

      <!-- Recent Posts Section -->
      <section class="pb-16 lg:pb-20">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <!-- Section heading with rule -->
          <div class="flex items-center gap-4 mb-8">
            <h2
              class="text-lg font-semibold text-gray-900 dark:text-white whitespace-nowrap"
            >
              最新記事
            </h2>
            <div class="h-px flex-1 bg-gray-200 dark:bg-gray-700"></div>
          </div>

          {
            recentPosts.length > 0 ? (
              <div class="divide-y divide-gray-100 dark:divide-gray-800">
                {recentPosts.map(post => {
                  const { slug, data, body } = post;
                  const { title, description, emoji, pubDate, category } = data;
                  const stats = readingTime(body);
                  const readMinutes = Math.ceil(stats.minutes);

                  return (
                    <article class="py-6 group">
                      <a
                        href={`/blog/${slug}/`}
                        class="flex items-start gap-4 focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg"
                        aria-label={`ブログ記事「${title}」を読む`}
                      >
                        <span
                          class="text-3xl mt-0.5 flex-shrink-0"
                          role="img"
                          aria-hidden="true"
                        >
                          {emoji || '📝'}
                        </span>
                        <div class="flex-1 min-w-0">
                          {category && (
                            <span class="text-xs font-medium text-primary-500 dark:text-primary-400 mb-1 block">
                              {category}
                            </span>
                          )}
                          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 leading-snug mb-1">
                            {title}
                          </h3>
                          <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 leading-relaxed mb-2">
                            {description}
                          </p>
                          <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-gray-500">
                            <time datetime={pubDate.toISOString()}>
                              {format(
                                parseISO(pubDate.toISOString()),
                                'yyyy/MM/dd',
                                { locale: ja }
                              )}
                            </time>
                            <span>約{readMinutes}分</span>
                          </div>
                        </div>
                      </a>
                    </article>
                  );
                })}
              </div>
            ) : (
              <p class="text-gray-500 dark:text-gray-400 py-8">
                まだ記事がありません。
              </p>
            )
          }

          <div class="mt-8">
            <a
              href="/blog/"
              class="inline-flex items-center gap-1.5 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 font-medium"
            >
              すべての記事を見る
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>

          <!-- Inline tags -->
          {
            popularTags.length > 0 && (
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-12 pt-8 border-t border-gray-100 dark:border-gray-800">
                <span class="text-xs font-medium text-gray-400 dark:text-gray-500">
                  人気のトピック:
                </span>
                {popularTags.map(({ tag }) => (
                  <a
                    href={`/tags/${encodeURIComponent(tag)}/`}
                    class="font-mono text-xs text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer siteConfig={siteConfig} />
  </div>
</BaseLayout>
