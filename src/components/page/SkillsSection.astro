---
interface Skill {
  name: string;
  category:
    | 'frontend'
    | 'backend'
    | 'database'
    | 'infrastructure'
    | 'tools'
    | 'other';
  description?: string;
  skillIcon?: string; // Skill Icons の識別子
  color?: string;
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;

// カテゴリ別にスキルをグループ化
const skillsByCategory = skills.reduce(
  (acc, skill) => {
    if (!acc[skill.category]) {
      acc[skill.category] = [];
    }
    acc[skill.category].push(skill);
    return acc;
  },
  {} as Record<string, Skill[]>
);

// カテゴリの表示名マッピング
const categoryNames = {
  frontend: 'フロントエンド',
  backend: 'バックエンド',
  database: 'データベース',
  infrastructure: 'インフラ',
  tools: 'ツール',
  other: 'その他',
};
---

<section class="mb-16">
  <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-8 text-center">
    Skills
  </h2>

  <div class="grid gap-8">
    {
      Object.entries(skillsByCategory).map(([category, categorySkills]) => (
        <div class="bg-white dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700/50 p-6">
          <h3 class="text-sm font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-6">
            {categoryNames[category as keyof typeof categoryNames]}
          </h3>

          <div class="grid md:grid-cols-2 gap-3">
            {categorySkills.map(skill => (
              <div class="flex items-center space-x-4 p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                {/* スキル名とレベル */}
                <div class="flex-1">
                  <div class="flex items-center justify-between mb-2">
                    <h4 class="font-medium text-gray-900 dark:text-white">
                      {skill.name}
                    </h4>
                    {skill.skillIcon ? (
                      <img
                        src={`https://skillicons.dev/icons?i=${skill.skillIcon}`}
                        alt={skill.name}
                        class="w-8 h-8"
                        loading="lazy"
                      />
                    ) : (
                      skill.color && (
                        <div
                          class="w-4 h-4 rounded-full border border-gray-300 dark:border-gray-600"
                          style={`background-color: ${skill.color};`}
                        />
                      )
                    )}
                  </div>

                  {/* 説明 */}
                  {skill.description && (
                    <p class="text-sm text-gray-600 dark:text-gray-300">
                      {skill.description}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
